# MongoDB connection string (without the DB name — it is appended automatically)
MONGO_URI=mongodb://127.0.0.1:27017

# Port the API server listens on
PORT=4000

# Secret used to sign JWTs
JWT_SECRET_KEY=change_me_to_a_long_random_string

# Cloudinary (optional). If unset, image uploads fall back to storing base64.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (optional). If unset, the payment step is simulated.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Platform commission percentage taken from each paid order (default 2)
PLATFORM_FEE_PERCENT=2

# SMTP for transactional email (optional). If unset, emails are logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ReScrapIt <no-reply@rescrapit.local>

# SMS provider for phone OTP (optional). If unset, the OTP is logged/returned in dev.
SMS_PROVIDER=
SMS_API_KEY=

# Public URL of the frontend (used in email links)
FRONTEND_URL=http://localhost:5173

# Comma-separated list of admin emails (bootstrap platform admins without DB edits)
ADMIN_EMAILS=

# Optional external semantic search service base URL
SEMANTIC_SEARCH_URL=http://localhost:8000
